{
  "name": "webtools-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:test": "./scripts/dev-with-stripe.sh",
    "stripe": "./tools/stripe-cli/stripe",
    "stripe:login": "./tools/stripe-cli/stripe login",
    "stripe:listen": "./tools/stripe-cli/stripe listen --events checkout.session.completed,customer.subscription.updated,customer.subscription.deleted --forward-to http://localhost:3000/api/webhooks/stripe",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "backoffice:dev": "cd backoffice && pnpm dev",
    "backoffice:build": "cd backoffice && pnpm build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "node --experimental-strip-types db/migrate.ts",
    "db:psql": "node --experimental-strip-types db/psql.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.37.3",
    "@google-cloud/pubsub": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.447.0",
    "next": "^15.1.0",
    "next-themes": "^0.3.0",
    "pg": "^8.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^20.4.0",
    "tailwind-merge": "^2.5.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2"
  }
}
